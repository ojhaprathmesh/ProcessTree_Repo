@model ProcessTree.Models.ViewModels.ProcessActionViewModel
@using ProcessTree.Models

@{
    ViewData["Title"] = "Process Item";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">▶ Process: @Model.ItemName</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-4">
                        Current weight:
                        <strong>@Model.ItemWeight.ToString("F2") kg</strong>
                    </p>

                    <form asp-action="Process" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ItemId" />
                        <input type="hidden" asp-for="ItemName" />
                        <input type="hidden" asp-for="ItemWeight" />

                        <div class="mb-3">
                            <label asp-for="OutputCount" class="form-label"></label>
                            <input asp-for="OutputCount" class="form-control" type="number" min="1" max="20"
                                   id="outputCountInput" />
                            <span asp-validation-for="OutputCount" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SplitMode" class="form-label"></label>
                            <select asp-for="SplitMode" class="form-select" id="splitModeSelect"
                                    asp-items="Html.GetEnumSelectList<WeightSplitMode>()">
                            </select>
                        </div>

                        <div class="mb-3" id="customWeightsSection" style="display:none;">
                            <label asp-for="CustomWeights" class="form-label"></label>
                            <input asp-for="CustomWeights" class="form-control"
                                   placeholder="e.g., 50.00, 30.00, 70.00" />
                            <div class="form-text">
                                Comma-separated. Count must match output count.
                                Total must not exceed @Model.ItemWeight.ToString("F2") kg.
                            </div>
                            <span asp-validation-for="CustomWeights" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                Run Processing
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.ItemId"
                               class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const splitSelect = document.getElementById('splitModeSelect');
        const customSection = document.getElementById('customWeightsSection');

        function toggleCustomWeights() {
            // Enum value 1 = Custom
            customSection.style.display =
                splitSelect.value === '1' ? 'block' : 'none';
        }

        splitSelect.addEventListener('change', toggleCustomWeights);
        toggleCustomWeights();
    </script>
}