@model List<ProcessTree.Models.ProcessItem>

@{
    ViewData["Title"] = "All Items";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Root Items</h2>
        <a asp-action="Create" class="btn btn-primary">+ Add New Item</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show">
            @TempData["Warning"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No items yet. Create your first root item to get started.
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Weight (kg)</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.Weight.ToString("F2")</td>
                        <td>
                            @if (item.IsProcessed)
                            {
                                <span class="badge bg-success">Processed</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Unprocessed</span>
                            }
                        </td>
                        <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-action="Tree" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">🌲 Tree</a>
                            @if (!item.IsProcessed)
                            {
                                <a asp-action="Process" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">▶ Process</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>