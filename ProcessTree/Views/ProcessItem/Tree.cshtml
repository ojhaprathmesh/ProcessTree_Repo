@model ProcessTree.Models.ViewModels.TreeNodeViewModel

@{
    ViewData["Title"] = "Processing Tree";
}

<link rel="stylesheet" href="~/css/tree.css" />

<div class="container-fluid mt-3 px-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">🌲 Tree: <strong>@Model.Name</strong></h4>
        <div class="d-flex gap-2">
            @if (!Model.IsProcessed)
            {
                <button class="btn btn-sm btn-outline-primary"
                        onclick="openProcessModal(@Model.Id, '@Html.Raw(Model.Name.Replace("'", "\\'"))', @Model.Weight)">
                    ▶ Process Root
                </button>
            }
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">Details</a>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back</a>
        </div>
    </div>

    <div id="toast-container" style="position:fixed;top:1rem;right:1rem;z-index:9999"></div>

    <div class="card shadow-sm">
        <div class="card-body p-2">
            <div class="tree-page-wrapper">
                <div id="tree-svg-container">
                    <svg id="tree-svg-lines"></svg>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-2">
        <small class="text-muted">
            <span class="me-3">🟩 Green = Processed</span>
            <span>🟨 Yellow = Unprocessed — click ▶ Process to go deeper</span>
        </small>
    </div>
</div>

<div class="modal fade" id="processModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">▶ Process: <span id="modal-item-name"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3">
                    Current weight: <strong id="modal-item-weight"></strong>
                </p>

                <div id="modal-error" class="alert alert-danger d-none"></div>

                <input type="hidden" id="modal-item-id" />
                <input type="hidden" id="modal-antiforgery" value="" />

                <div class="mb-3">
                    <label class="form-label">Number of Output Items</label>
                    <input type="number" id="modal-output-count" class="form-control" min="1" max="20" value="2" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Weight Split Mode</label>
                    <select id="modal-split-mode" class="form-select">
                        <option value="0">Equal</option>
                        <option value="1">Custom</option>
                    </select>
                </div>

                <div class="mb-3 d-none" id="modal-custom-section">
                    <label class="form-label">Custom Weights (comma-separated)</label>
                    <input type="text" id="modal-custom-weights" class="form-control"
                           placeholder="e.g., 50.00, 30.00, 70.00" />
                    <div class="form-text">
                        Count must match output count. Total must not exceed
                        <span id="modal-max-weight"></span> kg.
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="modal-submit-btn" onclick="submitProcess()">
                    Run Processing
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Antiforgery token (needed for POST) ────────────────────────────────
        // Fetch it from a hidden field rendered by the tag helper
        const __af = document.createElement('form');
        __af.innerHTML = '@Html.AntiForgeryToken()';
        document.body.appendChild(__af);
        const __afInput = __af.querySelector('input[name="__RequestVerificationToken"]');
        document.getElementById('modal-antiforgery').value = __afInput ? __afInput.value : '';
        document.body.removeChild(__af);

        // ── Tree data ──────────────────────────────────────────────────────────
        let treeData = @Html.Raw(
                    System.Text.Json.JsonSerializer.Serialize(Model,
                    new System.Text.Json.JsonSerializerOptions
                    {
                            PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
                    })
                    );

        // ── Layout constants ───────────────────────────────────────────────────
        const CARD_W = 100;
        const CARD_H = 95;
        const H_GAP = 10;
        const V_GAP = 60;

        // ── Tree layout helpers ────────────────────────────────────────────────
        function assignWidths(node) {
            if (!node.children || node.children.length === 0) {
                node._width = CARD_W;
                return;
            }
            node.children.forEach(assignWidths);
            const total = node.children.reduce((s, c) => s + c._width, 0)
                + H_GAP * (node.children.length - 1);
            node._width = Math.max(CARD_W, total);
        }

        function assignPositions(node, x, y) {
            node._x = x + (node._width - CARD_W) / 2;
            node._y = y;
            if (!node.children || node.children.length === 0) return;
            const totalChildW = node.children.reduce((s, c) => s + c._width, 0)
                + H_GAP * (node.children.length - 1);
            let cx = x + (node._width - totalChildW) / 2;
            node.children.forEach(child => {
                assignPositions(child, cx, y + CARD_H + V_GAP);
                cx += child._width + H_GAP;
            });
        }

        function collectNodes(node, list = []) {
            list.push(node);
            if (node.children) node.children.forEach(c => collectNodes(c, list));
            return list;
        }

        function collectEdges(node, edges = []) {
            if (node.children) {
                node.children.forEach(child => {
                    edges.push({ parent: node, child });
                    collectEdges(child, edges);
                });
            }
            return edges;
        }

        // ── Render tree ────────────────────────────────────────────────────────
        function render() {
            assignWidths(treeData);
            assignPositions(treeData, 0, 0);

            const allNodes = collectNodes(treeData);
            const allEdges = collectEdges(treeData);

            const maxX = Math.max(...allNodes.map(n => n._x + CARD_W));
            const maxY = Math.max(...allNodes.map(n => n._y + CARD_H));
            const canvasW = maxX + 20;
            const canvasH = maxY + 20;

            const container = document.getElementById('tree-svg-container');
            // Remove old cards (keep SVG element)
            [...container.querySelectorAll('.tree-card')].forEach(el => el.remove());

            container.style.width = canvasW + 'px';
            container.style.height = canvasH + 'px';

            const svg = document.getElementById('tree-svg-lines');
            svg.setAttribute('width', canvasW);
            svg.setAttribute('height', canvasH);
            svg.innerHTML = '';

            allEdges.forEach(({ parent, child }) => {
                const x1 = parent._x + CARD_W / 2, y1 = parent._y + CARD_H;
                const x2 = child._x + CARD_W / 2, y2 = child._y;
                const midY = (y1 + y2) / 2;
                const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                path.setAttribute('d',
                    `M ${x1} ${y1} C ${x1} ${midY}, ${x2} ${midY}, ${x2} ${y2}`);
                path.setAttribute('class', 'tree-edge');
                svg.appendChild(path);
            });

            allNodes.forEach(node => {
                const card = document.createElement('div');
                card.className = 'tree-card ' + (node.isProcessed ? 'processed' : 'unprocessed');
                card.style.left = node._x + 'px';
                card.style.top = node._y + 'px';

                const fromNote = node.notes && node.notes.startsWith('From:')
                    ? `<div class="card-from">${node.notes}</div>` : '';

                const escapedName = node.name.replace(/'/g, "\\'");
                const badge = node.isProcessed
                    ? `<span>✓ Done</span>`
                    : `<button class="process-btn"
                              onclick="openProcessModal(${node.id}, '${escapedName}', ${node.weight})">
                           ▶ Process
                       </button>`;

                card.innerHTML = `
                    <div class="card-label">${node.name}</div>
                    ${fromNote}
                    <div class="card-weight">⚖ ${node.weight.toFixed(2)} kg</div>
                    <div class="card-badge">${badge}</div>
                `;
                container.appendChild(card);
            });
        }

        // ── Modal helpers ──────────────────────────────────────────────────────
        const processModal = new bootstrap.Modal(
            document.getElementById('processModal'));

        document.getElementById('modal-split-mode').addEventListener('change', () => {
            const isCustom = document.getElementById('modal-split-mode').value === '1';
            document.getElementById('modal-custom-section')
                .classList.toggle('d-none', !isCustom);
        });

        function openProcessModal(id, name, weight) {
            document.getElementById('modal-item-id').value = id;
            document.getElementById('modal-item-name').textContent = name;
            document.getElementById('modal-item-weight').textContent = weight.toFixed(2) + ' kg';
            document.getElementById('modal-max-weight').textContent = weight.toFixed(2);
            document.getElementById('modal-output-count').value = 2;
            document.getElementById('modal-split-mode').value = '0';
            document.getElementById('modal-custom-section').classList.add('d-none');
            document.getElementById('modal-custom-weights').value = '';
            document.getElementById('modal-error').classList.add('d-none');
            processModal.show();
        }

        async function submitProcess() {
            const btn = document.getElementById('modal-submit-btn');
            btn.disabled = true;
            btn.textContent = 'Processing…';

            const itemId = document.getElementById('modal-item-id').value;
            const outputCount = document.getElementById('modal-output-count').value;
            const splitMode = document.getElementById('modal-split-mode').value;
            const customW = document.getElementById('modal-custom-weights').value;
            const token = document.getElementById('modal-antiforgery').value;

            const body = new URLSearchParams({
                ItemId: itemId,
                OutputCount: outputCount,
                SplitMode: splitMode,
                CustomWeights: customW,
                __RequestVerificationToken: token
            });

            // We need ItemName and ItemWeight too (controller expects them)
            const nameEl = document.getElementById('modal-item-name');
            const weightEl = document.getElementById('modal-item-weight');
            body.append('ItemName', nameEl.textContent);
            body.append('ItemWeight', weightEl.textContent.replace(' kg', '').trim());

            try {
                const resp = await fetch('/ProcessItem/ProcessAjax', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: body.toString()
                });

                const json = await resp.json();

                if (!resp.ok || json.error) {
                    showModalError(json.error || 'Something went wrong.');
                } else {
                    processModal.hide();
                    // Merge new data into treeData and re-render
                    applyProcessResult(json);
                    showToast(`✅ ${json.outputs.length} output item(s) created.`);
                }
            } catch (e) {
                showModalError('Network error. Please try again.');
            } finally {
                btn.disabled = false;
                btn.textContent = 'Run Processing';
            }
        }

        function showModalError(msg) {
            const el = document.getElementById('modal-error');
            el.textContent = msg;
            el.classList.remove('d-none');
        }

        // ── Patch tree data after successful process ───────────────────────────
        function applyProcessResult(json) {
            // json = { parentId, outputs: [{id, name, weight, isProcessed, notes}] }
            const parent = findNode(treeData, json.parentId);
            if (!parent) return;
            parent.isProcessed = true;
            parent.children = json.outputs.map(o => ({
                id: o.id,
                name: o.name,
                weight: o.weight,
                isProcessed: false,
                notes: o.notes,
                depth: (parent.depth || 0) + 1,
                children: []
            }));
            render();
        }

        function findNode(node, id) {
            if (node.id === id) return node;
            for (const c of (node.children || [])) {
                const found = findNode(c, id);
                if (found) return found;
            }
            return null;
        }

        // ── Toast ──────────────────────────────────────────────────────────────
        function showToast(msg) {
            const t = document.createElement('div');
            t.className = 'alert alert-success alert-dismissible fade show shadow';
            t.style.minWidth = '260px';
            t.innerHTML = `${msg}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
            document.getElementById('toast-container').appendChild(t);
            setTimeout(() => t.remove(), 4000);
        }

        // ── Initial render ─────────────────────────────────────────────────────
        render();
    </script>
}
