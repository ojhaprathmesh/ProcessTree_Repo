@model ProcessTree.Models.ViewModels.TreeNodeViewModel

@{
    ViewData["Title"] = "Processing Tree";
}

<link rel="stylesheet" href="~/css/tree.css" />

<div class="container-fluid mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3 px-3">
        <h2>🌲 Tree: <em>@Model.Name</em></h2>
        <div class="d-flex gap-2">
            @if (!Model.IsProcessed)
            {
                <a asp-action="Process" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">▶ Process Root</a>
            }
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">Details</a>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mx-3 alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm mx-3">
        <div class="card-body tree-wrapper">
            <div class="tree">
                @await Html.PartialAsync("_TreeNode", Model)
            </div>
        </div>
    </div>

    <div class="mx-3 mt-3">
        <small class="text-muted">
            <span class="me-3">🟩 Green border = Processed</span>
            <span>🟨 Yellow border = Unprocessed — click ▶ to process further</span>
        </small>
    </div>

</div>
```

---

### Build & Test

**Ctrl + Shift + B** → **▶ https**

Now click the 🌲 Tree button on any item — you should see the tree with nodes and connector lines.

Try this flow to really test it:
```
1. Create a new item (e.g., "Steel Batch", 300 kg)
2. Click ▶ Process (split into 3 equal outputs)
3. Click 🌲 Tree (see the tree with 3 children)
4. Click ▶ Process on one child (go deeper)
5. Click 🌲 Tree again (see 2-level tree)
```

